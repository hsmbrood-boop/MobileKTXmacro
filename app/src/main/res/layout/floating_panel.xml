<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panel_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#DD1a1a2e"
    android:padding="8dp"
    android:elevation="10dp">

    <!-- 헤더 / 드래그 핸들 -->
    <TextView
        android:id="@+id/tv_header"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:text="KTX 자동예매"
        android:textColor="#e94560"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#16213e" />

    <!-- 상태 표시 -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="대기 중"
        android:textColor="#64ffda"
        android:textSize="9sp"
        android:gravity="center"
        android:paddingTop="3dp"
        android:paddingBottom="3dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a4e" />

    <!-- 좌석예매 (절반 높이) -->
    <Button
        android:id="@+id/btn_seat"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:layout_marginTop="4dp"
        android:text="KTX 좌석예매"
        android:textSize="10sp"
        android:textColor="#ffffff"
        android:backgroundTint="#1565c0"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp" />

    <!-- 입석예매 (절반 높이) -->
    <Button
        android:id="@+id/btn_standing"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:layout_marginTop="2dp"
        android:text="KTX 입석포함"
        android:textSize="10sp"
        android:textColor="#ffffff"
        android:backgroundTint="#1565c0"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp" />

    <!-- 매크로 종료 (절반 높이) -->
    <Button
        android:id="@+id/btn_stop"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:layout_marginTop="2dp"
        android:text="■ 매크로 종료"
        android:textSize="10sp"
        android:textColor="#ffffff"
        android:backgroundTint="#c62828"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp" />

    <!-- 펼치기 / 접기 토글 화살표 -->
    <Button
        android:id="@+id/btn_toggle"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_marginTop="2dp"
        android:text="▼"
        android:textSize="9sp"
        android:textColor="#888888"
        android:backgroundTint="#16213e"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp" />

    <!-- ═══ 펼쳐지는 섹션 (기본: GONE) ═══ -->
    <LinearLayout
        android:id="@+id/ll_expandable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:background="#2a2a4e" />

        <!-- b1~b9 그리드 행 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <FrameLayout android:id="@+id/btn_b1" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#0f2030" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/img_b1" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:visibility="gone" />
                <TextView android:id="@+id/lbl_b1" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:text="b1" android:textColor="#64ffda" android:textSize="9sp" android:gravity="center" android:background="#880f2030" android:paddingTop="2dp" android:paddingBottom="2dp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/btn_b2" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#0a2a1e" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_b2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="b2&#10;미설정" android:textColor="#3a7a5a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/btn_b3" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#0a2a1e" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_b3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="b3&#10;미설정" android:textColor="#3a7a5a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

        </LinearLayout>

        <!-- b1~b9 그리드 행 2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

            <FrameLayout android:id="@+id/btn_b4" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#0a2a1e" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_b4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="b4&#10;미설정" android:textColor="#3a7a5a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/btn_b5" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#0a2a1e" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_b5" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="b5&#10;미설정" android:textColor="#3a7a5a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/btn_b6" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#0a2a1e" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_b6" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="b6&#10;미설정" android:textColor="#3a7a5a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

        </LinearLayout>

        <!-- b7~b9 그리드 행 3 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

            <FrameLayout android:id="@+id/btn_b7" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#0a2a1e" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_b7" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="b7&#10;미설정" android:textColor="#3a7a5a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/btn_b8" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#0a2a1e" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_b8" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="b8&#10;미설정" android:textColor="#3a7a5a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/btn_b9" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#0a2a1e" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_b9" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="b9&#10;미설정" android:textColor="#3a7a5a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

        </LinearLayout>

        <!-- b10~b12 그리드 행 4 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

            <FrameLayout android:id="@+id/btn_b10" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#0a2a1e" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_b10" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="b10&#10;미설정" android:textColor="#3a7a5a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/btn_b11" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#0a2a1e" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_b11" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="b11&#10;미설정" android:textColor="#3a7a5a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/btn_b12" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#0a2a1e" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_b12" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="b12&#10;미설정" android:textColor="#3a7a5a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:background="#2a2a4e" />

        <!-- 화면 캡처 재허용 -->
        <Button
            android:id="@+id/btn_capture_perm"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginTop="4dp"
            android:text="📷 화면 캡처 허용"
            android:textSize="10sp"
            android:textColor="#ffffff"
            android:backgroundTint="#1a5276"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp" />

        <!-- 패널 축소 -->
        <Button
            android:id="@+id/btn_minimize"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="4dp"
            android:text="패널 숨기기"
            android:textSize="11sp"
            android:textColor="#ffffff"
            android:backgroundTint="#2a2a4e"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <!-- 프로그램 종료 -->
        <Button
            android:id="@+id/btn_exit"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="3dp"
            android:text="프로그램 종료"
            android:textSize="11sp"
            android:textColor="#ffffff"
            android:backgroundTint="#4a0000"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <!-- 로그 표시 (최근 5줄) -->
        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="2dp"
            android:text=""
            android:textColor="#888888"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:background="#0a0a1a"
            android:padding="5dp"
            android:lineSpacingMultiplier="1.3" />

    </LinearLayout>

</LinearLayout>
