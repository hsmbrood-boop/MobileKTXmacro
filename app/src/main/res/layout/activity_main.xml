<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1a1a2e">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KTX 자동예매 매크로"
        android:textColor="#e94560"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <!-- 권한 상태 표시 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#16213e"
        android:padding="16dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/tv_perm_overlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬜ 다른 앱 위에 표시 권한"
            android:textColor="#8892b0"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_perm_accessibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬜ 접근성 서비스 권한"
            android:textColor="#8892b0"
            android:textSize="13sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tv_perm_capture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬜ 화면 캡처 권한"
            android:textColor="#8892b0"
            android:textSize="13sp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_grant_overlay"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="1. 오버레이 권한 허용"
        android:backgroundTint="#1565c0" />

    <Button
        android:id="@+id/btn_grant_accessibility"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:text="2. 접근성 서비스 허용"
        android:backgroundTint="#1565c0" />

    <Button
        android:id="@+id/btn_grant_capture"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:text="3. 화면 캡처 허용 및 시작"
        android:backgroundTint="#1565c0" />

    <Button
        android:id="@+id/btn_start"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="매크로 패널 시작"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#e94560"
        android:enabled="false" />

</LinearLayout>
