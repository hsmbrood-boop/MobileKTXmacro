<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panel_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#DD1a002a"
    android:padding="8dp"
    android:elevation="10dp">

    <!-- 헤더 / 드래그 핸들 -->
    <TextView
        android:id="@+id/tv_header"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:text="SRT 자동예매"
        android:textColor="#c084e8"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#21003a" />

    <!-- 상태 표시 -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="대기 중"
        android:textColor="#c084e8"
        android:textSize="9sp"
        android:gravity="center"
        android:paddingTop="3dp"
        android:paddingBottom="3dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#4a0072" />

    <!-- SRT 좌석예매 -->
    <Button
        android:id="@+id/btn_srt_seat"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="4dp"
        android:text="SRT 좌석예매"
        android:textSize="10sp"
        android:textColor="#ffffff"
        android:backgroundTint="#6a0572"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp" />

    <!-- SRT 입석포함예매 -->
    <Button
        android:id="@+id/btn_srt_standing"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="2dp"
        android:text="SRT 입석포함예매"
        android:textSize="10sp"
        android:textColor="#ffffff"
        android:backgroundTint="#6a0572"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp" />

    <!-- 매크로 종료 -->
    <Button
        android:id="@+id/btn_stop"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="2dp"
        android:text="■ 매크로 종료"
        android:textSize="11sp"
        android:textColor="#ffffff"
        android:backgroundTint="#c62828"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp" />

    <!-- 펼치기 / 접기 토글 화살표 -->
    <Button
        android:id="@+id/btn_toggle"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="2dp"
        android:text="▼"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#c084e8"
        android:backgroundTint="#21003a"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp" />

    <!-- 로그 표시 (항상 보임) -->
    <ScrollView
        android:id="@+id/scroll_log"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="4dp"
        android:background="#0a001a"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#888888"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:padding="5dp"
            android:lineSpacingMultiplier="1.3" />

    </ScrollView>

    <!-- ═══ 펼쳐지는 섹션 (기본: GONE) ═══ -->
    <LinearLayout
        android:id="@+id/ll_expandable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:background="#4a0072" />

        <!-- 그리드 행 1: sb1, sb2, sb3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <FrameLayout android:id="@+id/btn_sb1" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#1a0030" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/img_sb1" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:visibility="gone" />
                <TextView android:id="@+id/lbl_sb1" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:text="sb1" android:textColor="#c084e8" android:textSize="9sp" android:gravity="center" android:background="#881a0030" android:paddingTop="2dp" android:paddingBottom="2dp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/btn_sb2" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#1a0030" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/img_sb2" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:visibility="gone" />
                <TextView android:id="@+id/lbl_sb2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:text="sb2" android:textColor="#c084e8" android:textSize="9sp" android:gravity="center" android:background="#881a0030" android:paddingTop="2dp" android:paddingBottom="2dp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/btn_sb3" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#200a30" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_sb3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="sb3&#10;미설정" android:textColor="#7a3a9a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

        </LinearLayout>

        <!-- 그리드 행 2: sb4, sb5, sb6 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

            <FrameLayout android:id="@+id/btn_sb4" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#200a30" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_sb4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="sb4&#10;미설정" android:textColor="#7a3a9a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/btn_sb5" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#200a30" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_sb5" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="sb5&#10;미설정" android:textColor="#7a3a9a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/btn_sb6" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#200a30" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_sb6" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="sb6&#10;미설정" android:textColor="#7a3a9a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

        </LinearLayout>

        <!-- 그리드 행 3: sb7, sb8 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

            <FrameLayout android:id="@+id/btn_sb7" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#200a30" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_sb7" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="sb7&#10;미설정" android:textColor="#7a3a9a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

            <FrameLayout android:id="@+id/btn_sb8" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#200a30" android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/lbl_sb8" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="sb8&#10;미설정" android:textColor="#7a3a9a" android:textSize="9sp" android:padding="3dp" />
            </FrameLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:background="#4a0072" />

        <!-- 화면 캡처 허용 -->
        <Button
            android:id="@+id/btn_capture"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="4dp"
            android:text="📷 화면 캡처 허용"
            android:textSize="11sp"
            android:textColor="#ffffff"
            android:backgroundTint="#4a0072"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <!-- 백업 / 복원 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            <Button
                android:id="@+id/btn_backup"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="백업"
                android:textSize="11sp"
                android:textColor="#ffffff"
                android:backgroundTint="#1a6b3a"
                android:minWidth="0dp"
                android:minHeight="0dp" />
            <Button
                android:id="@+id/btn_restore"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="복원"
                android:textSize="11sp"
                android:textColor="#ffffff"
                android:backgroundTint="#7b3a1a"
                android:minWidth="0dp"
                android:minHeight="0dp" />
        </LinearLayout>

        <!-- 패널 숨기기 -->
        <Button
            android:id="@+id/btn_minimize"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="4dp"
            android:text="패널 숨기기(알림창 찾기가능)"
            android:textSize="11sp"
            android:textColor="#ffffff"
            android:backgroundTint="#4a0072"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <!-- 앱 종료 -->
        <Button
            android:id="@+id/btn_exit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="3dp"
            android:text="앱 종료하기"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:backgroundTint="#4a0000"
            android:minWidth="0dp"
            android:minHeight="0dp" />

    </LinearLayout>

</LinearLayout>
